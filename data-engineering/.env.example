# Data Engineering Environment Variables
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/communityboard
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=communityboard
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ETL Configuration
ETL_BATCH_SIZE=1000
ETL_SCHEDULE_INTERVAL=3600
ETL_LOG_LEVEL=INFO
ETL_DATA_DIR=./data
ETL_OUTPUT_DIR=./output

# Analytics Configuration
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_AGGREGATION_INTERVAL=daily
ANALYTICS_EXPORT_FORMAT=json

# External Data Sources
EXTERNAL_API_KEY=
EXTERNAL_API_URL=
EXTERNAL_API_TIMEOUT=30

# Data Warehouse (if using)
WAREHOUSE_HOST=
WAREHOUSE_PORT=5432
WAREHOUSE_DATABASE=analytics
WAREHOUSE_USER=
WAREHOUSE_PASSWORD=

# Message Queue (if using)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# File Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=communityboard-data
S3_PREFIX=analytics/

# Monitoring
# Sentry DSN - Error tracking service URL for ETL pipeline crash reports and monitoring
SENTRY_DSN=
DATADOG_API_KEY=
PROMETHEUS_GATEWAY=localhost:9091

# Spark Configuration (if using)
SPARK_MASTER=local[*]
SPARK_APP_NAME=CommunityBoard-ETL
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=1g

# Airflow Configuration (if using)
AIRFLOW_HOME=./airflow
AIRFLOW_DAGS_DIR=./dags
AIRFLOW_WEBSERVER_PORT=8081
AIRFLOW_EXECUTOR=LocalExecutor

# Python Configuration
PYTHONPATH=./src
PYTHON_ENV=development