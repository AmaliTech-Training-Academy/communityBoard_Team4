##############################################################################
# terraform.tfvars.example — copy to terraform.tfvars and fill in real values
# NEVER commit real credentials. Set db_password via TF_VAR_db_password.
##############################################################################

aws_region   = "eu-west-1"
project_name = "community-board"
environment  = "prod"       # prod | staging | dev

# ── Networking ────────────────────────────────────────────────────────────────
vpc_cidr             = "10.30.0.0/16"
public_subnet_cidrs  = ["10.30.0.0/24", "10.30.1.0/24"]
private_subnet_cidrs = ["10.30.10.0/24", "10.30.11.0/24"]
db_subnet_cidrs      = ["10.30.20.0/24", "10.30.21.0/24"]

admin_cidrs = ["<YOUR_OFFICE_OR_VPN_IP>/32"]

# ── Monitoring EC2 ───────────────────────────────────────────────────────────
monitoring_instance_type = "t3.medium"   # Prometheus + Grafana + Alertmanager

# ── ECS Fargate ───────────────────────────────────────────────────────────────
frontend_cpu           = 256
frontend_memory        = 512
backend_cpu            = 512
backend_memory         = 1024
frontend_desired_count = 1
backend_desired_count  = 1
image_tag              = "latest"



# ── RDS PostgreSQL ────────────────────────────────────────────────────────────
db_username              = "cbadmin"
# db_password            — export TF_VAR_db_password="<strong-random-password>"
db_instance_class        = "db.t3.micro"
db_allocated_storage     = 20
db_multi_az              = false
db_backup_retention_days = 7

# ── CI/CD ─────────────────────────────────────────────────────────────────────
# GitHub repository for OIDC trust scope: org/repo (no https://, no .git)
github_repo = "<your-github-org>/communityBoard_Team4"

# ── ECR ───────────────────────────────────────────────────────────────────────
ecr_repository_name = "community-board"
