# Backend Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env file to git

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/communityboard
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<your-db-password>

# JWT Configuration
JWT_SECRET=<generate-secure-random-string-min-256-bits>
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Server Configuration
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_AMALITECH=DEBUG

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# File Upload
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# Email Configuration (if needed)
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=<your-email>
SPRING_MAIL_PASSWORD=<your-app-password>
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_FROM=no-reply@communityboard.local
EMAIL_VERIFICATION_URL=http://localhost:3000/verify-email
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_FROM=no-reply@communityboard.local
FRONTEND_BASE_URL=http://localhost:3000

# Redis (if caching enabled)
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=<redis-password>

# Actuator Security
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

# API Documentation
SPRINGDOC_API_DOCS_PATH=/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html
