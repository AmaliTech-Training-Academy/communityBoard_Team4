# Frontend Environment Variables
# Copy this file to .env and update with your values

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_API_TIMEOUT=10000

# Authentication
REACT_APP_JWT_STORAGE_KEY=communityboard_token
REACT_APP_REFRESH_TOKEN_KEY=communityboard_refresh_token
REACT_APP_TOKEN_EXPIRY_BUFFER=300000

# Application Configuration
REACT_APP_APP_NAME=CommunityBoard
REACT_APP_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_NOTIFICATIONS=false
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_COMMENTS=true
REACT_APP_ENABLE_SEARCH=false

# UI Configuration
REACT_APP_POSTS_PER_PAGE=10
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_SUPPORTED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# External Services
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=

# Development Tools
REACT_APP_ENABLE_REDUX_DEVTOOLS=true
REACT_APP_ENABLE_CONSOLE_LOGS=true
REACT_APP_MOCK_API=false

# Build Configuration
GENERATE_SOURCEMAP=true
REACT_APP_BUILD_DATE=
REACT_APP_GIT_COMMIT=

# PWA Configuration
REACT_APP_ENABLE_PWA=false
REACT_APP_PWA_NAME=CommunityBoard
REACT_APP_PWA_SHORT_NAME=CB

# Social Media Integration
REACT_APP_FACEBOOK_APP_ID=
REACT_APP_TWITTER_API_KEY=
REACT_APP_LINKEDIN_CLIENT_ID=

# Map Integration (if needed)
REACT_APP_GOOGLE_MAPS_API_KEY=
REACT_APP_MAPBOX_ACCESS_TOKEN=

# Error Tracking
REACT_APP_BUGSNAG_API_KEY=
REACT_APP_LOGROCKET_APP_ID=

# Performance Monitoring
REACT_APP_NEW_RELIC_LICENSE_KEY=
REACT_APP_DATADOG_CLIENT_TOKEN=