# Frontend Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env file to git

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8080/api/v1
REACT_APP_API_TIMEOUT=30000

# Authentication
REACT_APP_JWT_STORAGE_KEY=communityboard_token
REACT_APP_REFRESH_TOKEN_KEY=communityboard_refresh_token

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_NOTIFICATIONS=false
REACT_APP_ENABLE_COMMENTS=true

# Environment
REACT_APP_ENV=development
REACT_APP_VERSION=0.0.1

# Analytics (if enabled)
REACT_APP_GOOGLE_ANALYTICS_ID=<your-ga-id>

# External Services
# Sentry DSN - Error tracking and monitoring service URL for frontend crash reports
REACT_APP_SENTRY_DSN=<your-sentry-dsn>

# Upload Configuration
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# Pagination
REACT_APP_DEFAULT_PAGE_SIZE=10
REACT_APP_MAX_PAGE_SIZE=100

# Build Configuration
GENERATE_SOURCEMAP=true
REACT_APP_BUILD_DATE=
REACT_APP_GIT_COMMIT=

# PWA Configuration
REACT_APP_ENABLE_PWA=false
REACT_APP_PWA_NAME=CommunityBoard
REACT_APP_PWA_SHORT_NAME=CB

# Social Media Integration
REACT_APP_FACEBOOK_APP_ID=
REACT_APP_TWITTER_API_KEY=
REACT_APP_LINKEDIN_CLIENT_ID=

# Map Integration (if needed)
REACT_APP_GOOGLE_MAPS_API_KEY=
REACT_APP_MAPBOX_ACCESS_TOKEN=

# Error Tracking
REACT_APP_BUGSNAG_API_KEY=
REACT_APP_LOGROCKET_APP_ID=

# Performance Monitoring
REACT_APP_NEW_RELIC_LICENSE_KEY=
REACT_APP_DATADOG_CLIENT_TOKEN=
