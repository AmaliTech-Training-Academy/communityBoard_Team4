##############################################################################
# Java / Maven
##############################################################################
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*

##############################################################################
# Node / React
##############################################################################
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

##############################################################################
# Python
##############################################################################
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
pip-log.txt

##############################################################################
# Terraform
##############################################################################
# Local state — never commit; state lives in S3
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/.terraform.lock.hcl

# Variable files that may contain secrets
devops/terraform/aws/terraform.tfvars
devops/terraform/aws/backend.hcl

# Generated SSH keys
devops/keys/

# Crash / debug logs
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

##############################################################################
# Docker
##############################################################################
.dockerignore

##############################################################################
# Environment / secrets — never commit real values
##############################################################################
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.pub
*/keys/*

##############################################################################
# Logs
##############################################################################
*.log
logs/

##############################################################################
# IDE / OS
##############################################################################
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Custom Ignores
Frontend-Execution-Plan.md
MCP-figma-setup-by-RoboNuggets.md

# Coverage reports (generated, not to be committed)
frontend/coverage/
